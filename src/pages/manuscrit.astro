---
import Nav from '../components/Nav.astro';
import Manuscrit from '../components/Manuscrit.astro';
import '../styles/global.css';
---
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Manuscrit de thèse — Thibault Barret" />
    <title>Manuscrit — Thibault Barret</title>
  </head>
  <body>
    <Nav />
    <main class="pt-16">
      <Manuscrit />
    </main>
    <footer class="py-6 text-center text-xs" style="color: var(--text-muted); border-top: 1px solid var(--border);">
      © {new Date().getFullYear()} Thibault Barret
    </footer>
  </body>
</html>

---
import { getCollection, render } from 'astro:content';
import Nav from '../../components/Nav.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const projects = await getCollection('programming');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const statusStyle: Record<string, string> = {
  'stable':   'background: #1e4d2b; color: #a6e3a1;',  // Catppuccin Green
  'en cours': 'background: #4a2d0a; color: #fab387;',  // Catppuccin Peach
};
---
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={project.data.description} />
    <title>{project.data.title} — Thibault Barret</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  </head>
  <body>
    <Nav />
    <main class="pt-16">
      <section class="py-24" style="background: var(--bg);">
        <div class="max-w-4xl mx-auto px-6">

          <a
            href="/programmation"
            class="inline-flex items-center gap-2 text-sm mb-10 transition-opacity hover:opacity-70"
            style="color: var(--text-muted);"
          >
            ← Retour aux projets
          </a>

          <div class="flex items-start justify-between gap-4 mb-4">
            <h1 class="font-serif text-4xl font-bold leading-tight" style="color: var(--text);">
              {project.data.title}
            </h1>
            <span
              class="text-xs font-medium px-3 py-1 rounded-full shrink-0 mt-2"
              style={statusStyle[project.data.status]}
            >
              {project.data.status}
            </span>
          </div>

          <div class="flex flex-wrap gap-2 mb-8">
            {project.data.tags.map(tag => (
              <span
                class="text-xs px-3 py-1 rounded-full"
                style="background: var(--bg-surface); color: var(--text-muted); border: 1px solid var(--border);"
              >
                {tag}
              </span>
            ))}
          </div>

          {project.data.github && (
            <a
              href={project.data.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded text-sm font-medium mb-10 transition-opacity hover:opacity-70"
              style="border: 1px solid var(--border); color: var(--text);"
            >
              GitHub →
            </a>
          )}

          <div
            class="prose max-w-none"
            style="color: var(--text);"
          >
            <Content />
          </div>

        </div>
      </section>
    </main>
    <footer class="py-6 text-center text-xs" style="color: var(--text-muted); border-top: 1px solid var(--border);">
      © {new Date().getFullYear()} Thibault Barret
    </footer>
  </body>
</html>

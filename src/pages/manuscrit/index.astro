---
import { getCollection } from 'astro:content';
import Nav from '../../components/Nav.astro';
import '../../styles/global.css';
import GithubSlugger from 'github-slugger';

function extractSections(body: string): { text: string; slug: string; level: number }[] {
  const slugger = new GithubSlugger();
  const sections: { text: string; slug: string; level: number }[] = [];
  for (const line of body.split('\n')) {
    const m = line.match(/^(#{1,3}) (.+)/);
    if (m) {
      const text = m[2].trim();
      sections.push({ text, slug: slugger.slug(text), level: m[1].length });
    }
  }
  return sections;
}

const chapters = (await getCollection('chapters'))
  .sort((a, b) => a.data.order - b.data.order);
---
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Manuscrit de thèse — Thibault Barret" />
    <title>Manuscrit — Thibault Barret</title>
  </head>
  <body>
    <Nav />
    <main class="pt-16">
      <div class="max-w-4xl mx-auto px-6 py-12">
        <h1 class="font-serif text-3xl font-bold mb-2" style="color: var(--text);">Manuscrit</h1>
        <div class="w-12 h-0.5 mb-12" style="background: var(--accent);"></div>

        <div class="space-y-10">
          {chapters.map(chapter => {
            const slug = chapter.id.replace(/\.md$/, '');
            const sections = extractSections(chapter.body ?? '');
            return (
              <section class="pb-8" style="border-bottom: 1px solid var(--border);">
                <a
                  href={`/manuscrit/${slug}`}
                  class="font-serif text-xl font-semibold hover:opacity-80 transition-opacity"
                  style="color: var(--text); text-decoration: none; display: block; margin-bottom: 0.5rem;"
                >
                  Chapitre {chapter.data.order} — {chapter.data.title}
                </a>

                {chapter.data.description && (
                  <p class="text-sm mb-3" style="color: var(--text-muted);">
                    {chapter.data.description}
                  </p>
                )}

                {sections.length > 0 && (
                  <ul class="space-y-1">
                    {sections.map(s => (
                      <li style={`padding-left: ${(s.level - 1) * 0.75}rem`}>
                        <a
                          href={`/manuscrit/${slug}#${s.slug}`}
                          class="text-sm hover:opacity-80 transition-opacity"
                          style="color: var(--accent); text-decoration: none;"
                        >
                          · {s.text}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </section>
            );
          })}
        </div>
      </div>
    </main>
    <footer class="py-6 text-center text-xs" style="color: var(--text-muted); border-top: 1px solid var(--border);">
      © {new Date().getFullYear()} Thibault Barret
    </footer>
  </body>
</html>

---
import { getCollection, render } from 'astro:content';
import Nav from '../../components/Nav.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const statusStyle: Record<string, string> = {
  'stable':   'background: #1e4d2b; color: #a6e3a1;',
  'en cours': 'background: #4a2d0a; color: #fab387;',
};
---
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={project.data.description} />
    <title>{project.data.title} — Thibault Barret</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" />
  </head>
  <body>
    <Nav />
    <main class="pt-16">
      <section class="py-24" style="background: var(--bg);">
        <div class="max-w-6xl mx-auto px-6">

          <a
            href="/#research"
            class="inline-flex items-center gap-2 text-sm mb-10 transition-opacity hover:opacity-70"
            style="color: var(--text-muted);"
          >
            ← Retour à la recherche
          </a>

          <div class="flex items-start justify-between gap-4 mb-4">
            <h1 class="font-serif text-4xl font-bold leading-tight" style="color: var(--text);">
              {project.data.title}
            </h1>
            {project.data.status && (
              <span
                class="text-xs font-medium px-3 py-1 rounded-full shrink-0 mt-2"
                style={statusStyle[project.data.status]}
              >
                {project.data.status}
              </span>
            )}
          </div>

          <div class="flex flex-wrap gap-2 mb-8">
            {project.data.tags.map(tag => (
              <span
                class="text-xs px-3 py-1 rounded-full"
                style="background: var(--bg-surface); color: var(--text-muted); border: 1px solid var(--border);"
              >
                {tag}
              </span>
            ))}
          </div>

          {project.data.figure && (
            <iframe
              src={`/figures/${project.data.figure}`}
              width="100%"
              height="500"
              loading="lazy"
              title={project.data.title}
              class="block rounded-lg mb-10 border"
              style="border-color: var(--border);"
            />
          )}

          <div class="prose max-w-none" style="color: var(--text);">
            <Content />
          </div>

        </div>
      </section>
    </main>
    <footer class="py-6 text-center text-xs" style="color: var(--text-muted); border-top: 1px solid var(--border);">
      © {new Date().getFullYear()} Thibault Barret
    </footer>
  </body>
</html>

<style is:global>
  .prose h1 {
    font-family: 'Lora', Georgia, serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .prose h2 {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }
  .prose h3 {
    font-family: 'Lora', Georgia, serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose p {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }
  .prose ul {
    color: var(--text-muted);
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    list-style-type: disc;
  }
  .prose ol {
    color: var(--text-muted);
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    list-style-type: decimal;
  }
  .prose li {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }
  .prose strong {
    font-weight: 600;
    color: var(--text);
  }
  .prose em {
    font-style: italic;
  }
  .prose code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    background: var(--bg-surface);
    padding: 0.2em 0.45em;
    border-radius: 0.25rem;
    border: 1px solid var(--border);
  }
  .prose pre {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .prose pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
  }
  .prose blockquote {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-muted);
    font-style: italic;
  }
  .prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }
  .prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover {
    opacity: 0.75;
  }
</style>

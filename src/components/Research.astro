---
// src/components/Research.astro
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter(p => p.data.show)
  .sort((a, b) => a.data.order - b.data.order);

const statusStyle: Record<string, string> = {
  'stable':   'background: #1e4d2b; color: #a6e3a1;',
  'en cours': 'background: #4a2d0a; color: #fab387;',
};
---

<section id="research" class="py-24 fade-in" style="background: var(--bg-surface);">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="font-serif text-3xl font-bold mb-2" style="color: var(--text);">Recherche</h2>
    <div class="w-12 h-0.5 mb-12" style="background: var(--accent);"></div>

    <div class="grid gap-8">
      {projects.map(project => (
        <a
          href={`/recherche/${project.slug}`}
          class="block rounded-lg overflow-hidden transition-opacity hover:opacity-90"
          style="border: 1px solid var(--border); background: var(--bg); text-decoration: none;"
        >
          {project.data.figure && (
            <img
              src={`/figures/${project.data.figure}`}
              alt={project.data.title}
              loading="lazy"
              class="block w-full border-b"
              style="border-color: var(--border); max-height: 280px; object-fit: cover;"
            />
          )}
          <div class="p-6">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-serif text-xl font-semibold" style="color: var(--text);">
                {project.data.title}
              </h3>
              {project.data.status && (
                <span
                  class="text-xs font-medium px-3 py-1 rounded-full shrink-0"
                  style={statusStyle[project.data.status]}
                >
                  {project.data.status}
                </span>
              )}
            </div>
            <p class="leading-relaxed mb-4" style="color: var(--text-muted);">
              {project.data.description}
            </p>
            <div class="flex flex-wrap items-center gap-2">
              {project.data.tags.map(tag => (
                <span
                  class="text-xs px-3 py-1 rounded-full"
                  style="background: var(--bg-surface); color: var(--text-muted); border: 1px solid var(--border);"
                >
                  {tag}
                </span>
              ))}
              <span class="ml-auto text-xs font-medium" style="color: var(--accent);">
                Voir la recherche →
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

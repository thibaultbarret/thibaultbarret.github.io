---
// src/components/CV.astro
const experiences = [
  {
    period: '2021 – présent',
    title: 'Doctorant',
    place: 'Institut de Recherche Dupuy de Lôme, UMR CNRS 6027, Université Bretagne Sud',
    description: "Identification inverse des paramètres matériaux de loi de comportement thermo-mécanique à partir d'essais hétérogènes et de méthode inverse.",
    tags: ['Analyse inverse', 'FEMU', 'DIC', 'MFront', 'Python'],
  },
];

const formations = [
  {
    period: '2019 – 2021',
    title: 'Master Génie Mécanique et Matériaux',
    place: 'Université Bretagne Sud',
    description: '',
    tags: ['Mécanique des solides', 'Matériaux', 'Éléments finis'],
  },
  {
    period: '2020 – 2021',
    title: 'Master recherche Mécanique, Matériaux et Génie Civil',
    place: 'Université Bretagne Sud - ENSTA Bretagne - INSA Rennes',
    description: '',
    tags: ['Mécanique des matériaux', 'Génie Civil', 'Recherche'],
  },
];

const competences: { categorie: string; tags: string[] }[] = [
  {
    categorie: 'Langages',
    tags: ['Python', 'C++', 'LaTeX', 'Bash'],
  },
  {
    categorie: 'Méthodes',
    tags: ['Analyse inverse', 'Identifiabilité', 'FEMU', 'DIC', 'Éléments finis'],
  },
  {
    categorie: 'Outils',
    tags: ['MFront', 'MTest', 'Cast3M', 'Tree-sitter', 'LSP', 'Git'],
  },
];
---

<section id="cv" class="py-24 fade-in" style="background: var(--bg-surface);">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="font-serif text-3xl font-bold mb-2" style="color: var(--text);">CV</h2>
    <div class="w-12 h-0.5 mb-4" style="background: var(--accent);"></div>

    <div class="mb-12">
      <a
        href="/cv.pdf"
        download
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded font-medium text-sm transition-opacity hover:opacity-80"
        style="background: var(--accent); color: #fff;"
      >
        ↓ Télécharger le CV (PDF)
      </a>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <div>
        <h3 class="font-serif text-xl font-semibold mb-6" style="color: var(--text);">Expériences</h3>
        <ol class="relative border-l" style="border-color: var(--border);">
          {experiences.map(exp => (
            <li class="mb-8 ml-6">
              <span
                class="absolute -left-2 w-4 h-4 rounded-full"
                style="background: var(--accent);"
              />
              <time class="text-xs font-mono" style="color: var(--text-muted);">{exp.period}</time>
              <p class="font-semibold mt-1" style="color: var(--text);">{exp.title}</p>
              <p class="text-sm mb-1" style="color: var(--accent);">{exp.place}</p>
              {exp.description && (
                <p class="text-sm mb-2" style="color: var(--text-muted);">{exp.description}</p>
              )}
              {exp.tags && exp.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-2">
                  {exp.tags.map(tag => (
                    <span
                      class="text-xs px-2 py-0.5 rounded"
                      style="background: var(--bg); color: var(--text-muted); border: 1px solid var(--border);"
                    >
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </li>
          ))}
        </ol>
      </div>

      <div>
        <h3 class="font-serif text-xl font-semibold mb-6" style="color: var(--text);">Formation</h3>
        <ol class="relative border-l" style="border-color: var(--border);">
          {formations.map(f => (
            <li class="mb-8 ml-6">
              <span
                class="absolute -left-2 w-4 h-4 rounded-full"
                style="background: var(--accent);"
              />
              <time class="text-xs font-mono" style="color: var(--text-muted);">{f.period}</time>
              <p class="font-semibold mt-1" style="color: var(--text);">{f.title}</p>
              <p class="text-sm" style="color: var(--accent);">{f.place}</p>
              {f.tags && f.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-2">
                  {f.tags.map(tag => (
                    <span
                      class="text-xs px-2 py-0.5 rounded"
                      style="background: var(--bg); color: var(--text-muted); border: 1px solid var(--border);"
                    >
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </li>
          ))}
        </ol>
      </div>
    </div>

    <div class="mt-16">
      <h3 class="font-serif text-xl font-semibold mb-8" style="color: var(--text);">Compétences</h3>
      <div class="space-y-5">
        {competences.map(({ categorie, tags }) => (
          <div class="flex gap-4 items-start">
            <span class="text-xs font-mono pt-1 w-24 shrink-0" style="color: var(--text-muted);">
              {categorie}
            </span>
            <div class="flex flex-wrap gap-2">
              {tags.map(tag => (
                <span
                  class="text-xs px-3 py-1 rounded"
                  style="background: var(--bg); color: var(--text); border: 1px solid var(--border);"
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

---
interface Props { src: string; height?: number | string; }
const { src, height = 500 } = Astro.props;
const heightCss = typeof height === 'string' ? height : `${height}px`;
---

<div
  class="vtk3d-figure"
  data-src={src}
  style={`height:${heightCss}; display:flex; overflow:hidden; background:#1e1e2e; border-radius:0.25rem;`}
>
  <div class="vtk3d-canvas" style="flex:1; position:relative; overflow:hidden;">

    <div class="vtk3d-loading" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:20;">
      <span style="color:#a6adc8;font:12px monospace;">Chargement…</span>
    </div>

    <!-- Sélecteur de champ (mode maillage unique, plusieurs champs) -->
    <div class="vtk3d-fields" style="display:none;position:absolute;top:10px;right:10px;gap:6px;flex-wrap:wrap;justify-content:flex-end;z-index:10;"></div>

    <!-- Légende double maillage -->
    <div class="vtk3d-legend" style="display:none;position:absolute;top:10px;left:10px;flex-direction:column;gap:6px;z-index:10;padding:8px 10px;background:rgba(24,24,37,.85);border-radius:4px;border:1px solid #45475a;"></div>

    <!-- Bouton reset vue -->
    <button class="vtk3d-reset" title="Réinitialiser la vue" style="display:none;position:absolute;bottom:10px;right:10px;background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:13px;width:28px;height:28px;cursor:pointer;padding:0;z-index:10;">⟳</button>

    <!-- Tooltip valeur scalaire -->
    <div class="vtk3d-tooltip" style="display:none;position:absolute;pointer-events:none;z-index:30;background:rgba(24,24,37,.92);border:1px solid #45475a;border-radius:4px;padding:3px 7px;color:#cdd6f4;font:11px monospace;white-space:nowrap;"></div>

    <!-- Colorbar -->
    <canvas class="vtk3d-cb-canvas" width="16" height="200" style="position:absolute;right:44px;top:50%;transform:translateY(-100px);border-radius:3px;border:1px solid #45475a;pointer-events:none;z-index:10;display:block;"></canvas>
    <span   class="vtk3d-cb-title"  style="position:absolute;right:20px;top:50%;transform:translateY(-118px);color:#cdd6f4;font:11px monospace;white-space:nowrap;pointer-events:none;z-index:10;"></span>
    <div    class="vtk3d-cb-labels" style="position:absolute;right:64px;top:50%;transform:translateY(-100px);height:200px;pointer-events:none;z-index:10;"></div>

    <!-- Contrôles slider -->
    <div class="vtk3d-controls" style="display:none;position:absolute;bottom:0;left:0;right:90px;padding:8px 12px;background:rgba(24,24,37,.85);z-index:10;align-items:center;gap:6px;">
      <button class="vtk3d-first" title="Premier pas"   style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏮</button>
      <button class="vtk3d-prev"  title="Pas précédent" style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏪</button>
      <button class="vtk3d-play"  title="Lecture"       style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">▶</button>
      <button class="vtk3d-next"  title="Pas suivant"   style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏩</button>
      <button class="vtk3d-last"  title="Dernier pas"   style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏭</button>
      <input  class="vtk3d-slider" type="range" min="0" max="0" step="1" value="0" style="flex:1;accent-color:#89b4fa;height:4px;" />
      <span   class="vtk3d-label"  style="color:#a6adc8;font:10px monospace;white-space:nowrap;">1/1</span>
    </div>

  </div>

  <!-- Panneau texte -->
  <div class="vtk3d-text-panel" style="display:none;width:280px;overflow-y:auto;padding:20px 18px;background:rgba(24,24,37,.95);border-left:1px solid #45475a;flex-shrink:0;">
    <div class="vtk3d-text-content" style="color:#cdd6f4;font:13px/1.75 sans-serif;"></div>
  </div>

</div>

<script>
import '@kitware/vtk.js/Rendering/Profiles/Geometry';
import vtkGenericRenderWindow           from '@kitware/vtk.js/Rendering/Misc/GenericRenderWindow';
import vtkMapper                        from '@kitware/vtk.js/Rendering/Core/Mapper';
import vtkActor                         from '@kitware/vtk.js/Rendering/Core/Actor';
import vtkColorTransferFunction         from '@kitware/vtk.js/Rendering/Core/ColorTransferFunction';
import vtkPolyData                      from '@kitware/vtk.js/Common/DataModel/PolyData';
import vtkDataArray                     from '@kitware/vtk.js/Common/Core/DataArray';
import vtkPoints                        from '@kitware/vtk.js/Common/Core/Points';
import vtkCellArray                     from '@kitware/vtk.js/Common/Core/CellArray';
import vtkInteractorStyleTrackballCamera from '@kitware/vtk.js/Interaction/Style/InteractorStyleTrackballCamera';
import vtkPointPicker                   from '@kitware/vtk.js/Rendering/Core/PointPicker';

// ── Colormaps ─────────────────────────────────────────────────────────────
const CMAPS: Record<string, [number,number,number,number][]> = {
  viridis:  [[0,.267,.005,.329],[.25,.282,.341,.631],[.5,.129,.569,.553],[.75,.369,.788,.384],[1,.993,.906,.144]],
  RdYlGn_r: [[0,.694,.004,.149],[.25,.992,.682,.380],[.5,1,1,.749],[.75,.549,.769,.290],[1,.165,.373,.165]],
  coolwarm: [[0,.230,.299,.754],[.5,.865,.865,.865],[1,.706,.016,.150]],
  jet:      [[0,0,0,.5],[.125,0,0,1],[.375,0,1,1],[.625,1,1,0],[.875,1,0,0],[1,.5,0,0]],
};

function interpolateCmap(stops: [number,number,number,number][], t: number): [number,number,number,number] {
  for (let i = 1; i < stops.length; i++) {
    if (t <= stops[i][0]) {
      const f = (t - stops[i-1][0]) / (stops[i][0] - stops[i-1][0]);
      return [t, ...([1,2,3] as const).map(k => stops[i-1][k] + (stops[i][k] - stops[i-1][k]) * f)] as any;
    }
  }
  return stops.at(-1)!;
}

// ── Parser .npy ───────────────────────────────────────────────────────────
interface NpyArray { data: ArrayLike<number>; shape: number[] }

async function fetchNpy(url: string): Promise<NpyArray> {
  const buf   = await fetch(url).then(r => r.arrayBuffer());
  const bytes = new Uint8Array(buf);
  const major = bytes[6];
  const hlen  = major === 1 ? (bytes[8] | bytes[9] << 8) : (bytes[8] | bytes[9]<<8 | bytes[10]<<16 | bytes[11]<<24);
  const hOff  = (major === 1 ? 10 : 12);
  const header = new TextDecoder().decode(bytes.slice(hOff, hOff + hlen));
  const dtype  = (header.match(/'descr'\s*:\s*'([^']+)'/) ?? ['','<f8'])[1];
  const shape  = (header.match(/'shape'\s*:\s*\(([^)]*)\)/) ?? ['',''])[1]
    .split(',').map(s => s.trim()).filter(Boolean).map(Number);
  const raw = buf.slice(hOff + hlen);
  let data: ArrayLike<number>;
  if      (dtype.endsWith('f8')) data = new Float64Array(raw);
  else if (dtype.endsWith('f4')) data = new Float32Array(raw);
  else if (dtype.endsWith('i4') || dtype.endsWith('u4')) data = new Int32Array(raw);
  else if (dtype.endsWith('i8') || dtype.endsWith('u8')) { const b = new BigInt64Array(raw); data = Int32Array.from(b, v => Number(v)); }
  else if (dtype.endsWith('i2') || dtype.endsWith('u2')) data = new Int16Array(raw);
  else data = new Float64Array(raw);
  return { data, shape };
}

function idx(arr: ArrayLike<number>, shape: number[], ...ix: number[]) {
  let o = 0, s = 1;
  for (let i = shape.length - 1; i >= 0; i--) { o += (ix[i] ?? 0) * s; s *= shape[i]; }
  return arr[o] as number;
}

function formatValue(v: number, fmt: string): string {
  const m = fmt.match(/^\.(\d+)([efg])$/);
  if (!m) return String(v);
  const n = parseInt(m[1]);
  if (m[2] === 'e') return v.toExponential(n);
  if (m[2] === 'f') return v.toFixed(n);
  return v.toPrecision(n);
}

function drawColorbar(container: HTMLElement, name: string, stops: [number,number,number,number][], vmin: number, vmax: number, nColors: number, labelFmt: string) {
  const title  = container.querySelector<HTMLElement>('.vtk3d-cb-title')!;
  const canvas = container.querySelector<HTMLCanvasElement>('.vtk3d-cb-canvas')!;
  const labels = container.querySelector<HTMLElement>('.vtk3d-cb-labels')!;
  labels.innerHTML = '';
  title.textContent = name;
  const ctx = canvas.getContext('2d')!;
  const bandH = 200 / nColors;
  for (let i = 0; i < nColors; i++) {
    const t = (nColors - 1 - i + 0.5) / nColors;
    const [, r, g, b] = interpolateCmap(stops, t);
    ctx.fillStyle = `rgb(${(r*255)|0},${(g*255)|0},${(b*255)|0})`;
    ctx.fillRect(0, Math.floor(i * bandH), 16, Math.ceil(bandH) + 1);
  }
  for (let i = 0; i <= nColors; i++) {
    const v = vmin + (vmax - vmin) * (1 - i / nColors);
    const s = document.createElement('span');
    s.style.cssText = `position:absolute;top:${i * 200 / nColors}px;right:0;transform:translateY(-50%);color:#a6adc8;font:10px monospace;text-align:right;white-space:nowrap;`;
    s.textContent = formatValue(v, labelFmt);
    labels.appendChild(s);
  }
}

// ── Constructeurs de maillage ─────────────────────────────────────────────

function buildPositions3D(coords: NpyArray, disp: NpyArray | null, stepIdx: number): Float32Array {
  const N = coords.shape[0];
  const pos = new Float32Array(N * 3);
  for (let i = 0; i < N; i++) {
    let x = idx(coords.data, coords.shape, i, 0);
    let y = idx(coords.data, coords.shape, i, 1);
    let z = idx(coords.data, coords.shape, i, 2);
    if (disp) {
      x += disp.shape.length === 3 ? idx(disp.data, disp.shape, i, 0, stepIdx) : idx(disp.data, disp.shape, i, 0);
      y += disp.shape.length === 3 ? idx(disp.data, disp.shape, i, 1, stepIdx) : idx(disp.data, disp.shape, i, 1);
      z += disp.shape.length === 3 ? idx(disp.data, disp.shape, i, 2, stepIdx) : idx(disp.data, disp.shape, i, 2);
    }
    pos[i*3] = x; pos[i*3+1] = y; pos[i*3+2] = z;
  }
  return pos;
}

function makeTriangleCells(triangles: NpyArray): Uint32Array {
  const T = triangles.shape[0];
  const buf = new Uint32Array(T * 4);
  for (let t = 0; t < T; t++) {
    buf[t*4]   = 3;
    buf[t*4+1] = idx(triangles.data, triangles.shape, t, 0);
    buf[t*4+2] = idx(triangles.data, triangles.shape, t, 1);
    buf[t*4+3] = idx(triangles.data, triangles.shape, t, 2);
  }
  return buf;
}

function makeQuadCells(connectivity: NpyArray): Uint32Array {
  const E = connectivity.shape[0];
  const buf = new Uint32Array(E * 5);
  for (let e = 0; e < E; e++) {
    buf[e*5]   = 4;
    buf[e*5+1] = idx(connectivity.data, connectivity.shape, e, 0);
    buf[e*5+2] = idx(connectivity.data, connectivity.shape, e, 1);
    buf[e*5+3] = idx(connectivity.data, connectivity.shape, e, 2);
    buf[e*5+4] = idx(connectivity.data, connectivity.shape, e, 3);
  }
  return buf;
}

function buildScalars(fields: NpyArray, stepIdx: number, fieldIdx: number): Float32Array {
  const N = fields.shape[0];
  const out = new Float32Array(N);
  for (let i = 0; i < N; i++) {
    out[i] = fields.shape.length === 3 ? idx(fields.data, fields.shape, i, fieldIdx, stepIdx)
           : fields.shape.length === 2 ? idx(fields.data, fields.shape, i, fieldIdx)
           : (fields.data[i] as number);
  }
  return out;
}

function fieldRange(sc: Float32Array): [number, number] {
  let vmin = Infinity, vmax = -Infinity;
  for (let i = 0; i < sc.length; i++) {
    if (isFinite(sc[i])) { vmin = Math.min(vmin, sc[i]); vmax = Math.max(vmax, sc[i]); }
  }
  return [vmin, vmax];
}

// ── Init ──────────────────────────────────────────────────────────────────
async function initVtk3D(container: HTMLElement) {
  const cfg = await fetch(container.dataset.src!).then(r => r.json());

  const hasDic   = !!cfg.dic;
  const hasFe    = !!cfg.fe;
  const dualMode = hasDic && hasFe;

  const { cmap = 'RdYlGn_r', n_colors = 10, opacity = 0.8, label_format = '.2e' } = cfg;
  const steps: { step: number; text?: string }[] = cfg.steps ?? [];
  const cmapStops = CMAPS[cmap] ?? CMAPS['viridis'];

  type FieldDef = { index: number; name: string };
  const fieldsConfig: FieldDef[] = cfg.fields_config
    ?? [{ index: cfg.field_index ?? 0, name: cfg.field_name ?? 'Field' }];

  // ── Chargement ────────────────────────────────────────────────────────
  type DicMesh = { coords: NpyArray; triangles: NpyArray; disp: NpyArray | null };
  type FeMesh  = { coords: NpyArray; connectivity: NpyArray; disp: NpyArray | null };

  const [dicMesh, feMesh, fieldsArr] = await Promise.all([
    hasDic ? (async (): Promise<DicMesh> => ({
      coords:    await fetchNpy(cfg.dic.coords),
      triangles: await fetchNpy(cfg.dic.triangulation),
      disp:      cfg.dic.displacements ? await fetchNpy(cfg.dic.displacements) : null,
    }))() : Promise.resolve(null as DicMesh | null),
    hasFe ? (async (): Promise<FeMesh> => ({
      coords:       await fetchNpy(cfg.fe.coords),
      connectivity: await fetchNpy(cfg.fe.connectivity),
      disp:         cfg.fe.displacements ? await fetchNpy(cfg.fe.displacements) : null,
    }))() : Promise.resolve(null as FeMesh | null),
    (!dualMode && cfg.fields) ? fetchNpy(cfg.fields) : Promise.resolve(null as NpyArray | null),
  ]);

  // ── Renderer ─────────────────────────────────────────────────────────
  const canvasEl = container.querySelector<HTMLElement>('.vtk3d-canvas')!;
  await new Promise<void>(resolve => requestAnimationFrame(() => resolve()));
  const rw = vtkGenericRenderWindow.newInstance();
  rw.setContainer(canvasEl);
  rw.resize();
  const renderer = rw.getRenderer();
  renderer.setBackground(0.118, 0.118, 0.173);
  const renWin = rw.getRenderWindow();

  // Caméra : convention DIC (Y vers le bas, regarde vers +Z)
  const cam = renderer.getActiveCamera();
  cam.setViewUp(0, -1, 0);
  rw.getInteractor().setInteractorStyle(vtkInteractorStyleTrackballCamera.newInstance());

  // ── PolyData + acteurs ────────────────────────────────────────────────
  const hasSca = !dualMode && !!fieldsArr;
  if (!hasSca) {
    container.querySelector<HTMLCanvasElement>('.vtk3d-cb-canvas')!.style.display = 'none';
    container.querySelector<HTMLElement>('.vtk3d-cb-title')!.style.display = 'none';
    container.querySelector<HTMLElement>('.vtk3d-cb-labels')!.style.display = 'none';
  }
  const lut    = vtkColorTransferFunction.newInstance();

  function configureLut(vmin: number, vmax: number) {
    lut.removeAllPoints();
    const range = (vmax - vmin) || 1;
    const eps   = range * 1e-7;
    for (let i = 0; i < n_colors; i++) {
      const t    = (i + 0.5) / n_colors;
      const [, r, g, b] = interpolateCmap(cmapStops, t);
      const v_lo = vmin + (i / n_colors) * range;
      const v_hi = vmin + ((i + 1) / n_colors) * range;
      lut.addRGBPoint(v_lo, r, g, b);
      if (i < n_colors - 1) lut.addRGBPoint(v_hi - eps, r, g, b);
    }
    lut.setMappingRange(vmin, vmax);
    lut.updateRange();
  }

  type MeshPd = { pd: any; pts: any; scalarsArr: any };

  function buildPd(N: number, cells: Uint32Array): MeshPd {
    const pd  = vtkPolyData.newInstance();
    const pts = vtkPoints.newInstance();
    pts.setData(new Float32Array(N * 3), 3);
    pd.setPoints(pts);
    const polys = vtkCellArray.newInstance();
    polys.setData(cells);
    pd.setPolys(polys);
    const scalarsArr = hasSca
      ? vtkDataArray.newInstance({ name: 'field', values: new Float32Array(N), numberOfComponents: 1 })
      : null;
    if (scalarsArr) pd.getPointData().setScalars(scalarsArr);
    return { pd, pts, scalarsArr };
  }

  function addActor(pd: any, fixedColor?: [number, number, number]): any {
    const mapper = vtkMapper.newInstance();
    mapper.setInputData(pd);
    mapper.setScalarVisibility(hasSca && !fixedColor);
    if (hasSca && !fixedColor) mapper.setLookupTable(lut);
    const actor = vtkActor.newInstance();
    actor.setMapper(mapper);
    actor.getProperty().setOpacity(opacity);
    actor.getProperty().setLighting(false);
    if (fixedColor) actor.getProperty().setColor(...fixedColor);
    renderer.addActor(actor);
    return mapper;
  }

  const dicPd  = dicMesh ? buildPd(dicMesh.coords.shape[0], makeTriangleCells(dicMesh.triangles)) : null;
  const fePd   = feMesh  ? buildPd(feMesh.coords.shape[0],  makeQuadCells(feMesh.connectivity))   : null;
  const dicMapper = dicPd ? addActor(dicPd.pd,  dualMode ? [0.455, 0.780, 0.925] : undefined) : null;
  const feMapper  = fePd  ? addActor(fePd.pd,   dualMode ? [0.980, 0.702, 0.529] : undefined) : null;

  // Mapper actif pour setScalarRange (mode maillage unique)
  const activeMapper = dicMapper ?? feMapper!;
  const activePd     = dicPd    ?? fePd!;

  // ── Panneau texte ─────────────────────────────────────────────────────
  const textPanel   = container.querySelector<HTMLElement>('.vtk3d-text-panel')!;
  const textContent = container.querySelector<HTMLElement>('.vtk3d-text-content')!;
  const hasText = steps.some(s => s.text);
  if (hasText) textPanel.style.display = 'block';

  // ── Légende double maillage ───────────────────────────────────────────
  if (dualMode) {
    const legend = container.querySelector<HTMLElement>('.vtk3d-legend')!;
    legend.style.display = 'flex';
    [['#74c7ec', 'DIC'], ['#fab387', 'EF']].forEach(([color, label]) => {
      const row = document.createElement('div');
      row.style.cssText = 'display:flex;align-items:center;gap:6px;';
      const dot = document.createElement('span');
      dot.style.cssText = `width:10px;height:10px;border-radius:50%;background:${color};flex-shrink:0;`;
      const txt = document.createElement('span');
      txt.style.cssText = 'color:#cdd6f4;font:11px monospace;';
      txt.textContent = label;
      row.append(dot, txt);
      legend.appendChild(row);
    });
  }

  // ── Sélecteur de champs ───────────────────────────────────────────────
  let currentFieldIdx = fieldsConfig[0].index;
  const fieldsDiv = container.querySelector<HTMLElement>('.vtk3d-fields')!;
  if (hasSca && fieldsConfig.length > 1) {
    fieldsDiv.style.display = 'flex';
    fieldsConfig.forEach(({ index, name }) => {
      const btn = document.createElement('button');
      btn.textContent = name;
      btn.dataset.idx = String(index);
      const active = index === fieldsConfig[0].index;
      btn.style.cssText = `padding:3px 10px;font:11px monospace;border-radius:4px;cursor:pointer;border:1px solid #45475a;background:${active?'#89b4fa':'#313244'};color:${active?'#1e1e2e':'#cdd6f4'};`;
      btn.addEventListener('click', async () => {
        fieldsDiv.querySelectorAll('button').forEach(b => {
          (b as HTMLElement).style.background = '#313244';
          (b as HTMLElement).style.color = '#cdd6f4';
        });
        btn.style.background = '#89b4fa'; btn.style.color = '#1e1e2e';
        await render(currentSliderPos, index);
      });
      fieldsDiv.appendChild(btn);
    });
  }

  // ── Rendu ─────────────────────────────────────────────────────────────
  let currentSliderPos = 0;
  let lastStepIdx = -1;

  async function render(stepPos: number, fieldIdx: number) {
    const stepIdx = steps.length > 0 ? steps[stepPos].step : 0;
    const positionsChanged = stepIdx !== lastStepIdx;

    if (dicPd && dicMesh) {
      dicPd.pts.setData(buildPositions3D(dicMesh.coords, dicMesh.disp, stepIdx), 3);
      dicPd.pts.modified(); dicPd.pd.modified();
    }
    if (fePd && feMesh) {
      fePd.pts.setData(buildPositions3D(feMesh.coords, feMesh.disp, stepIdx), 3);
      fePd.pts.modified(); fePd.pd.modified();
    }

    if (hasSca && fieldsArr && activePd.scalarsArr) {
      const newScalars = buildScalars(fieldsArr, stepIdx, fieldIdx);
      const [vmin, vmax] = fieldRange(newScalars);
      if (!isFinite(vmin) || !isFinite(vmax)) { renWin.render(); return; }
      for (let i = 0; i < newScalars.length; i++) {
        if (!isFinite(newScalars[i])) newScalars[i] = vmin;
      }
      activePd.scalarsArr.setData(newScalars);
      activePd.scalarsArr.modified();
      activePd.pd.modified();
      configureLut(vmin, vmax);
      activeMapper.setScalarRange(vmin, vmax);
      const fieldName = fieldsConfig.find(f => f.index === fieldIdx)?.name ?? String(fieldIdx);
      drawColorbar(container, fieldName, cmapStops, vmin, vmax, n_colors, label_format);
      currentFieldIdx = fieldIdx;
    }

    if (hasText) textContent.innerHTML = steps[stepPos]?.text ?? '';
    if (positionsChanged) { renderer.resetCamera(); lastStepIdx = stepIdx; }
    renWin.render();
  }

  // ── Slider ────────────────────────────────────────────────────────────
  const controls = container.querySelector<HTMLElement>('.vtk3d-controls')!;
  const slider   = container.querySelector<HTMLInputElement>('.vtk3d-slider')!;
  const labelEl  = container.querySelector<HTMLElement>('.vtk3d-label')!;
  const playBtn  = container.querySelector<HTMLButtonElement>('.vtk3d-play')!;
  const firstBtn = container.querySelector<HTMLButtonElement>('.vtk3d-first')!;
  const prevBtn  = container.querySelector<HTMLButtonElement>('.vtk3d-prev')!;
  const nextBtn  = container.querySelector<HTMLButtonElement>('.vtk3d-next')!;
  const lastBtn  = container.querySelector<HTMLButtonElement>('.vtk3d-last')!;
  let animTimer: ReturnType<typeof setInterval> | null = null;

  function stopAnim() {
    if (animTimer) { clearInterval(animTimer); animTimer = null; playBtn.textContent = '▶'; }
  }

  async function goTo(pos: number) {
    currentSliderPos = Math.max(0, Math.min(pos, steps.length - 1));
    labelEl.textContent = `${currentSliderPos + 1}/${steps.length}`;
    slider.value = String(currentSliderPos);
    await render(currentSliderPos, currentFieldIdx);
  }

  if (steps.length > 1) {
    controls.style.display = 'flex';
    slider.max = String(steps.length - 1);
    slider.addEventListener('input', () => { stopAnim(); goTo(parseInt(slider.value)); });
    firstBtn.addEventListener('click', () => { stopAnim(); goTo(0); });
    prevBtn.addEventListener('click',  () => { stopAnim(); goTo(currentSliderPos - 1); });
    nextBtn.addEventListener('click',  () => { stopAnim(); goTo(currentSliderPos + 1); });
    lastBtn.addEventListener('click',  () => { stopAnim(); goTo(steps.length - 1); });
    playBtn.addEventListener('click', () => {
      if (animTimer) { stopAnim(); }
      else { playBtn.textContent = '⏸'; animTimer = setInterval(() => goTo((currentSliderPos + 1) % steps.length), 200); }
    });
  }

  // ── Premier rendu ─────────────────────────────────────────────────────
  await render(0, currentFieldIdx);
  renderer.resetCamera();
  renWin.render();
  container.querySelector<HTMLElement>('.vtk3d-loading')!.style.display = 'none';
  new ResizeObserver(() => { rw.resize(); renWin.render(); }).observe(canvasEl);

  // ── Bouton reset vue ──────────────────────────────────────────────────
  const resetBtn = container.querySelector<HTMLButtonElement>('.vtk3d-reset')!;
  resetBtn.style.display = 'block';
  // Sauvegarde l'état caméra après le premier resetCamera()
  const initCamPos    = cam.getPosition().slice() as [number,number,number];
  const initCamFocal  = cam.getFocalPoint().slice() as [number,number,number];
  const initCamUp     = cam.getViewUp().slice() as [number,number,number];
  const initParScale  = cam.getParallelScale();
  resetBtn.addEventListener('click', () => {
    cam.setPosition(...initCamPos);
    cam.setFocalPoint(...initCamFocal);
    cam.setViewUp(...initCamUp);
    cam.setParallelScale(initParScale);
    renWin.render();
  });

  // ── Tooltip valeur scalaire ───────────────────────────────────────────
  if (hasSca && activePd.scalarsArr) {
    const tooltip = container.querySelector<HTMLElement>('.vtk3d-tooltip')!;
    const picker  = vtkPointPicker.newInstance();
    picker.setTolerance(0.01);

    // Coordonnées CSS pour positionner le tooltip dans le DOM
    let cssX = 0, cssY = 0;
    canvasEl.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = canvasEl.getBoundingClientRect();
      cssX = e.clientX - rect.left;
      cssY = e.clientY - rect.top;
    });
    canvasEl.addEventListener('mouseleave', () => { tooltip.style.display = 'none'; });

    // L'interacteur fournit des coordonnées déjà converties (devicePixelRatio, Y-flip)
    rw.getInteractor().onMouseMove((callData: any) => {
      const pos = callData.position;
      picker.pick([pos.x, pos.y, 0], renderer);
      const ptId = picker.getPointId();
      if (ptId >= 0 && ptId < activePd.scalarsArr.getNumberOfTuples()) {
        const val = activePd.scalarsArr.getValue(ptId);
        if (isFinite(val)) {
          tooltip.textContent = formatValue(val, label_format);
          tooltip.style.display = 'block';
          const rect = canvasEl.getBoundingClientRect();
          tooltip.style.left = `${Math.min(cssX + 12, rect.width - 90)}px`;
          tooltip.style.top  = `${Math.max(cssY - 28, 4)}px`;
          return;
        }
      }
      tooltip.style.display = 'none';
    });
  }
}

function showError(container: HTMLElement, err: unknown) {
  const msg = err instanceof Error ? err.message : String(err);
  const div = container.querySelector<HTMLElement>('.vtk3d-loading')!;
  div.innerHTML = `<span style="color:#f38ba8;font:11px monospace;padding:16px;text-align:center;max-width:80%;">Erreur VTK : ${msg}</span>`;
  div.style.flexDirection = 'column';
  console.error('[VtkFigure3D]', err);
}

function setup() {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(({ isIntersecting, target }) => {
      if (!isIntersecting) return;
      (target as HTMLElement).dataset.ready = '1';
      obs.unobserve(target);
      initVtk3D(target as HTMLElement).catch(e => showError(target as HTMLElement, e));
    });
  }, { threshold: 0.05 });
  document.querySelectorAll<HTMLElement>('.vtk3d-figure:not([data-ready])').forEach(el => obs.observe(el));
  document.querySelectorAll('details').forEach(d => {
    d.addEventListener('toggle', () => {
      if (!d.open) return;
      d.querySelectorAll<HTMLElement>('.vtk3d-figure:not([data-ready])').forEach(el => {
        el.dataset.ready = '1'; obs.unobserve(el);
        initVtk3D(el).catch(e => showError(el, e));
      });
    });
  });
}
document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', setup) : setup();
</script>

---
interface Props { src: string; height?: number | string; }
const { src, height = 500 } = Astro.props;
const heightCss = typeof height === 'string' ? height : `${height}px`;
---

<div
  class="vtk3d-figure"
  data-src={src}
  style={`height:${heightCss}; display:flex; overflow:hidden; background:#1e1e2e; border-radius:0.25rem;`}
>
  <div class="vtk3d-canvas" style="flex:1; position:relative; overflow:hidden;">

    <div class="vtk3d-loading" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:20;">
      <span style="color:#a6adc8;font:12px monospace;">Chargement…</span>
    </div>

    <!-- Sélecteur de champ (mode maillage unique, plusieurs champs) -->
    <div class="vtk3d-fields" style="display:none;position:absolute;top:10px;right:10px;gap:6px;flex-wrap:wrap;justify-content:flex-end;z-index:10;"></div>

    <!-- Légende double maillage -->
    <div class="vtk3d-legend" style="display:none;position:absolute;top:10px;left:10px;flex-direction:column;gap:6px;z-index:10;padding:8px 10px;background:rgba(24,24,37,.85);border-radius:4px;border:1px solid #45475a;"></div>

    <!-- Colorbar -->
    <canvas class="vtk3d-cb-canvas" width="16" height="200" style="position:absolute;right:44px;top:50%;transform:translateY(-100px);border-radius:3px;border:1px solid #45475a;pointer-events:none;z-index:10;display:block;"></canvas>
    <span   class="vtk3d-cb-title"  style="position:absolute;right:20px;top:50%;transform:translateY(-118px);color:#cdd6f4;font:11px monospace;white-space:nowrap;pointer-events:none;z-index:10;"></span>
    <div    class="vtk3d-cb-labels" style="position:absolute;right:64px;top:50%;transform:translateY(-100px);height:200px;pointer-events:none;z-index:10;"></div>

    <!-- Contrôles slider -->
    <div class="vtk3d-controls" style="display:none;position:absolute;bottom:0;left:0;right:90px;padding:8px 12px;background:rgba(24,24,37,.85);z-index:10;align-items:center;gap:6px;">
      <button class="vtk3d-first" title="Premier pas"   style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏮</button>
      <button class="vtk3d-prev"  title="Pas précédent" style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏪</button>
      <button class="vtk3d-play"  title="Lecture"       style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">▶</button>
      <button class="vtk3d-next"  title="Pas suivant"   style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏩</button>
      <button class="vtk3d-last"  title="Dernier pas"   style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏭</button>
      <input  class="vtk3d-slider" type="range" min="0" max="0" step="1" value="0" style="flex:1;accent-color:#89b4fa;height:4px;" />
      <span   class="vtk3d-label"  style="color:#a6adc8;font:10px monospace;white-space:nowrap;">1/1</span>
    </div>

  </div>

  <!-- Panneau texte -->
  <div class="vtk3d-text-panel" style="display:none;width:280px;overflow-y:auto;padding:20px 18px;background:rgba(24,24,37,.95);border-left:1px solid #45475a;flex-shrink:0;">
    <div class="vtk3d-text-content" style="color:#cdd6f4;font:13px/1.75 sans-serif;"></div>
  </div>

</div>

<script>
// placeholder
</script>

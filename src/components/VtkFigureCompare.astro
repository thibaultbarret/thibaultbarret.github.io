---
// VtkFigureCompare — 2 ou 3 sous-figures 2D à colormap/échelle partagée.
// JSON : voir docs/superpowers/specs/2026-06-05-vtk-figure-compare-design.md
//   { cmap, n_colors, opacity, label_format, label_color, vmin?, vmax?,
//     fields_config | field_index/field_name, steps[],
//     panels: [ { title, coords, triangles, fields, displacements?, images?|image? } ] }
interface Props { src: string; height?: number | string; }
const { src, height = 450 } = Astro.props;
const heightCss = typeof height === 'string' ? height : `${height}px`;
---

<div
  class="vtkc-figure"
  data-src={src}
  style={`height:${heightCss}; display:flex; flex-direction:column; overflow:hidden; background:#1e1e2e; border-radius:0.25rem; position:relative;`}
>
  <!-- Spinner -->
  <div class="vtkc-loading" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:20;">
    <span style="color:#a6adc8;font:12px monospace;">Chargement…</span>
  </div>

  <!-- Zone haute : rangée de panneaux + colorbar partagée -->
  <div style="flex:1; display:flex; overflow:hidden; position:relative;">

    <!-- Rangée de panneaux (remplie dynamiquement par le script) -->
    <div class="vtkc-panels" style="flex:1; display:flex; gap:2px; overflow:hidden;"></div>

    <!-- Boutons globaux -->
    <button class="vtkc-link"  title="Lier / délier les caméras" style="display:none;position:absolute;bottom:10px;right:90px;background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:13px;width:28px;height:28px;cursor:pointer;padding:0;z-index:10;">🔗</button>
    <button class="vtkc-reset" title="Réinitialiser la vue"      style="display:none;position:absolute;bottom:10px;right:54px;background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:13px;width:28px;height:28px;cursor:pointer;padding:0;z-index:10;">⟳</button>

    <!-- Colorbar partagée -->
    <div class="vtkc-cb" style="position:relative; width:90px; flex-shrink:0;">
      <canvas class="vtkc-cb-canvas" width="20" height="300" style="position:absolute;left:24px;top:50%;transform:translateY(-150px);border-radius:3px;border:1px solid #45475a;pointer-events:none;display:block;"></canvas>
      <span   class="vtkc-cb-title"  style="position:absolute;left:0;top:50%;transform:translateY(-172px);color:#cdd6f4;font:12px monospace;white-space:nowrap;pointer-events:none;"></span>
      <div    class="vtkc-cb-labels" style="position:absolute;left:48px;top:50%;transform:translateY(-150px);height:300px;pointer-events:none;"></div>
    </div>

  </div>

  <!-- Barre de contrôles partagée -->
  <div class="vtkc-controls" style="display:none;padding:8px 12px;background:rgba(24,24,37,.85);align-items:center;gap:6px;flex-shrink:0;">
    <div class="vtkc-fields" style="display:none;gap:6px;flex-wrap:wrap;margin-right:8px;"></div>
    <button class="vtkc-first" title="Premier pas"   style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏮</button>
    <button class="vtkc-prev"  title="Pas précédent" style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏪</button>
    <button class="vtkc-play"  title="Lecture"       style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">▶</button>
    <button class="vtkc-next"  title="Pas suivant"   style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏩</button>
    <button class="vtkc-last"  title="Dernier pas"   style="background:#313244;border:1px solid #45475a;border-radius:4px;color:#cdd6f4;font-size:11px;width:24px;height:24px;cursor:pointer;padding:0;">⏭</button>
    <input  class="vtkc-slider" type="range" min="0" max="0" step="1" value="0" style="flex:1;accent-color:#89b4fa;height:4px;" />
    <datalist class="vtkc-datalist"></datalist>
    <span   class="vtkc-label"  style="color:#a6adc8;font:10px monospace;white-space:nowrap;">1/1</span>
  </div>
</div>

<script>
import { initCompare } from '../scripts/vtk-compare-runtime';

function setup() {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(({ isIntersecting, target }) => {
      if (!isIntersecting) return;
      (target as HTMLElement).dataset.ready = '1';
      obs.unobserve(target);
      initCompare(target as HTMLElement).catch(e => {
        console.error('[VtkFigureCompare]', e);
        const div = (target as HTMLElement).querySelector<HTMLElement>('.vtkc-loading')!;
        const msg = e instanceof Error ? e.message : String(e);
        div.innerHTML = `<span style="color:#f38ba8;font:11px monospace;padding:16px;text-align:center;max-width:80%;">Erreur VTK : ${msg}</span>`;
      });
    });
  }, { threshold: 0.05 });
  document.querySelectorAll<HTMLElement>('.vtkc-figure:not([data-ready])').forEach(el => obs.observe(el));
}
document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', setup) : setup();
</script>
